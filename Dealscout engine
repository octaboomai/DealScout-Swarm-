class ProviderNotConfigured(Exception):
    """Raised when a provider is missing required credentials. Distinct from
    transient failures (timeouts, 429s) so the retry logic doesn't waste
    exponential-backoff delays retrying something that can never succeed."""
    pass


def _with_retries(fn, *args, max_retries=SEARCH_MAX_RETRIES, base_delay=SEARCH_RETRY_BASE_DELAY, **kwargs):
    """Retries a search backend call on transient failure (timeouts, 429s, etc.)
    with exponential backoff. Missing-credential failures skip retries entirely
    and fail fast, since no amount of waiting fixes a missing API key."""
    last_exc = None
    for attempt in range(max_retries + 1):
        try:
            return fn(*args, **kwargs)
        except ProviderNotConfigured as e:
            raise  # fail fast, no point retrying a missing key
        except Exception as e:
            last_exc = e
            if attempt < max_retries:
                delay = base_delay * (2 ** attempt)
                print(f"    [RETRY] {fn.__name__} failed ({e}); retrying in {delay:.1f}s...")
                time.sleep(delay)
    raise last_exc


def _search_via_serper(query: str, max_results: int = 5) -> list:
    if not SERPER_API_KEY:
        raise ProviderNotConfigured("SERPER_API_KEY not set")
    resp = httpx.post(
        "https://google.serper.dev/search",
        headers={"X-API-KEY": SERPER_API_KEY, "Content-Type": "application/json"},
        json={"q": query, "gl": SEARCH_REGION, "hl": "en", "num": max_results},
        timeout=10,
    )
    resp.raise_for_status()
    organic = resp.json().get("organic", [])[:max_results]
    return [{"title": r.get("title", ""), "body": r.get("snippet", ""), "href": r.get("link", "")} for r in organic]


def _search_via_brave(query: str, max_results: int = 5) -> list:
    if not BRAVE_API_KEY:
        raise ProviderNotConfigured("BRAVE_API_KEY not set")
    resp = httpx.get(
        "https://api.search.brave.com/res/v1/web/search",
        headers={"X-Subscription-Token": BRAVE_API_KEY, "Accept": "application/json"},
        params={"q": query, "country": SEARCH_REGION, "count": max_results},
        timeout=10,
    )
    resp.raise_for_status()
    results = resp.json().get("web", {}).get("results", [])[:max_results]
    return [{"title": r.get("title", ""), "body": r.get("description", ""), "href": r.get("url", "")} for r in results]


def _search_via_google_cse(query: str, max_results: int = 5) -> list:
    if not (GOOGLE_CSE_API_KEY and GOOGLE_CSE_CX):
        raise ProviderNotConfigured("GOOGLE_CSE_API_KEY / GOOGLE_CSE_CX not set")
    resp = httpx.get(
        "https://www.googleapis.com/customsearch/v1",
        params={"key": GOOGLE_CSE_API_KEY, "cx": GOOGLE_CSE_CX, "q": query,
                "gl": SEARCH_REGION, "num": min(max_results, 10)},
        timeout=10,
    )
    resp.raise_for_status()
    items = resp.json().get("items", [])[:max_results]
    return [{"title": r.get("title", ""), "body": r.get("snippet", ""), "href": r.get("link", "")} for r in items]


def _search_via_ddgs(query: str, max_results: int = 5) -> list:
    region = f"{SEARCH_REGION}-en"
    with DDGS(timeout=10) as ddgs:
        return list(ddgs.text(query, region=region, safesearch="off", max_results=max_results))


_SEARCH_BACKENDS = {
    "serper": _search_via_serper,
    "brave": _search_via_brave,
    "google_cse": _search_via_google_cse,
    "ddgs": _search_via_ddgs,
}


def tool_web_search(query: str) -> str:
    """Tries each configured provider in SEARCH_PROVIDER_PRIORITY order, retrying
    transient failures within a provider before moving to the next one. Providers
    with no API key configured raise immediately (no network call wasted) and are
    skipped. Only fails outright if every provider in the list is exhausted."""
    clean_query = query.replace("top 3", "").replace("latest", "").strip()
    if not clean_query:
        clean_query = "market analysis"

    errors = []
    for provider in SEARCH_PROVIDER_PRIORITY:
        backend = _SEARCH_BACKENDS.get(provider)
        if backend is None:
            errors.append(f"{provider}: unknown provider name")
            continue
        print(f"    [TOOL_EXEC] Trying provider='{provider}' region='{SEARCH_REGION}': {clean_query!r}")
        try:
            results = _with_retries(backend, clean_query)
        except Exception as e:
            print(f"    [WARN] provider='{provider}' exhausted retries: {e}")
            errors.append(f"{provider}: {e}")
            continue

        if not results:
            errors.append(f"{provider}: no results")
            continue

        lines = [f"(results via {provider}, region={SEARCH_REGION})"]
        for i, r in enumerate(results):
            title = r.get("title", "")
            url = r.get("href", "") or r.get("link", "")
            body = r.get("body", "") or r.get("snippet", "")
            lines.append(f"[{i+1}] {title} — {url}\n    {body}")
        return "\n".join(lines)

    return "LIVE SEARCH FAILED across all configured providers: " + "; ".join(errors)


def tool_lookup_indian_company(company_name: str) -> str:
    """
    Structured lookup for an Indian company via a Tofler / Probe42 / MCA21-backed
    provider. NOT WIRED TO A LIVE API -- scaffolding only. Get a developer key from
    Tofler (tofler.in) or Probe42 (probe42.in), set INDIA_REGISTRY_PROVIDER /
    INDIA_REGISTRY_API_KEY, and replace the body with the real request from their docs.
    Returns an explicit "not configured" message rather than ever fabricating data.
    """
    if INDIA_REGISTRY_PROVIDER == "none" or not INDIA_REGISTRY_API_KEY:
        return (
            "INDIA REGISTRY LOOKUP NOT CONFIGURED: set INDIA_REGISTRY_PROVIDER and "
            "INDIA_REGISTRY_API_KEY (e.g. a Tofler or Probe42 account) to pull structured "
            "company/financial/compliance data instead of relying on web search alone. "
            f"Falling back to web search for '{company_name}'."
        )
    return f"INDIA REGISTRY LOOKUP NOT YET IMPLEMENTED for provider '{INDIA_REGISTRY_PROVIDER}'."

