# WHY THIS CHANGED: the original raised RuntimeError at *import time* if
# GROQ_API_KEY was missing. On Streamlit Cloud that means the whole app -- including
# any diagnostics/status page -- fails to render at all on a fresh deploy before
# secrets are configured, with nothing but a stack trace. The engine now loads fine
# either way; get_client() raises a clear, catchable error only when the swarm is
# actually run without a key, so the rest of the app (status checks, the UI itself)
# still works and can tell the user exactly what to fix.
_client = None

def get_client() -> Groq:
    global _client
    if _client is None:
        api_key = os.environ.get("GROQ_API_KEY")
        if not api_key:
            raise RuntimeError(
                "GROQ_API_KEY is not set. On Streamlit Cloud: App settings -> Secrets, "
                "add GROQ_API_KEY = \"...\" as a root-level key, then reboot the app."
            )
        _client = Groq(api_key=api_key)
    return _client

